# Auto-detect text files and normalise line endings to LF in the repo.
# On checkout, Git converts to the OS-native line ending (CRLF on Windows).
* text=auto eol=lf

# Ensure these are always treated as text with LF in the repo
*.ts    text eol=lf
*.vue   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.mako  text eol=lf
*.txt   text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.toml  text eol=lf

# Binary files — do not touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
